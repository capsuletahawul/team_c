# Committed template — lists variable NAMES only, no real values.
# Copy this file to .env and fill in real values for local development.
# .env itself must NEVER be committed (see Handbook Section 1.7).

# Port the Express server listens on
PORT=5000

# development | production
NODE_ENV=development

# Secret used to sign/verify JWTs. Use a long, random string —
# never reuse this placeholder in production.
JWT_SECRET=replace_with_a_long_random_string

# Access token lifetime (short-lived by design, see Handbook Section 7.3)
JWT_EXPIRES_IN=15m

# The exact frontend origin allowed to call this API (no wildcards — see
# Handbook Section 12.3). Update to the deployed frontend URL in production.
CORS_ORIGIN=http://localhost:5173
